# Copy this file to .env before running `docker compose up --build`.
# Every value here already has a safe default baked into docker-compose.yml,
# so an empty/untouched copy of this file is enough to boot locally.

# Only enforced when NODE_ENV=production (index.js refuses to boot with
# the dev fallback in prod). Generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-secret-change-me

# development | production
NODE_ENV=development

# Optional: protect the /docs Swagger UI with HTTP Basic Auth.
# Leave blank locally.
DOCS_USER=
DOCS_PASSWORD=
